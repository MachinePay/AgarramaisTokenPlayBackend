{
  "name": "agarramais-credits-backend",
  "version": "1.0.0",
  "description": "API SaaS de creditos digitais e gamificacao para claw machines (integracao CompactPay)",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "npm run build && node dist/scripts/start-production.js",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "admin:ensure": "tsx src/scripts/ensure-admin.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.2.0",
    "@prisma/client": "^5.20.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "prisma": "^5.20.0",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.2"
  }
}
