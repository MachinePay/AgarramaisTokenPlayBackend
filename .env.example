# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agarramais_credits?schema=public"

# Servidor
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# Autenticacao
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Integracao CompactPay (telemetria das maquinas)
# Ver src/integrations/compactpay/compactpay.client.ts
# COMPACTPAY_API_URL ja tem default fixo no codigo (env.ts) apontando pro
# backend real da CompactPay - so precisa ser sobrescrita aqui se um dia
# existir um ambiente de staging/homolog diferente do de producao.
# COMPACTPAY_API_EMAIL/PASSWORD precisam ser de um Usuario cadastrado na
# CompactPay (tabela usuarios) com visibilidade sobre as maquinas do Agarra
# Mais - role=admin, ou role de cliente com o mesmo cliente_id do dono das
# maquinas. Sem isso o /pagamentos/creditos-digitais retorna 401/404.
# COMPACTPAY_API_URL="https://compactpayback.onrender.com/api/v1"
COMPACTPAY_API_EMAIL="integracao@agarramais.com.br"
COMPACTPAY_API_PASSWORD="change-me"
COMPACTPAY_MOCK=true

# Integracao Mercado Pago (Checkout Pro: cartao + Pix na mesma pagina deles)
# Ver src/integrations/mercadopago/mercadopago.client.ts
# MP_ACCESS_TOKEN e o Access Token PRIVADO de PRODUCAO da aplicacao no Mercado
# Pago. Em producao ele normalmente comeca com APP_USR-. Se usar TEST- o
# checkout fica em modo teste e cliente real nao consegue pagar. Nao confundir
# com a Public Key, que e usada no frontend.
MP_ACCESS_TOKEN=""
MP_API_BASE_URL="https://api.mercadopago.com"
MP_MOCK=true

# Base do WebApp (para back_urls de sucesso/pendente/falha do checkout) e URL
# publica deste backend (para o Mercado Pago conseguir chamar o webhook).
APP_BASE_URL="http://localhost:5173"
BACKEND_PUBLIC_URL="http://localhost:3333"

# Criacao/recuperacao de admin inicial:
# ADMIN_EMAIL="admin@agarramais.com.br"
# ADMIN_PASSWORD="troque-esta-senha"
# ADMIN_NAME="Administrador Agarra Mais"
# ADMIN_CPF="00000000000"
